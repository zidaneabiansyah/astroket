---
import { getFeaturedProjects } from '../data/projects';

const projects = getFeaturedProjects();
---

<section class="featured-projects section" id="featured">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Featured Projects</h2>
      <p class="section-subtitle">Showcase of my best work and recent projects</p>
    </div>

    <div class="projects-grid">
      {projects.map((project, index) => (
        <div class="project-card" data-index={index}>
          <div class="card-image-wrapper">
            <img src={project.image} alt={project.title} class="card-image" />
            <div class="card-overlay">
              <div class="overlay-buttons">
                {project.liveUrl && (
                  <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-primary">
                    Live Demo
                  </a>
                )}
                {project.githubUrl && (
                  <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-secondary">
                    GitHub
                  </a>
                )}
              </div>
            </div>
          </div>
          
          <div class="card-content">
            <span class="card-category">{project.category}</span>
            <h3 class="card-title">{project.title}</h3>
            <p class="card-description">{project.shortDescription}</p>
            
            <div class="card-tech-stack">
              {project.technologies.map((tech) => (
                <span class="tech-badge">{tech}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="view-all-section">
      <a href="/portfolio" class="btn btn-primary btn-lg">
        View All Projects
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4.16669 10H15.8334M15.8334 10L10 4.16669M15.8334 10L10 15.8334" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .featured-projects {
    background: linear-gradient(135deg, rgba(50, 69, 255, 0.03) 0%, rgba(188, 82, 238, 0.03) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-title {
    font-size: var(--font-size-5xl);
    font-weight: 800;
    margin-bottom: var(--spacing-md);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-3xl);
  }

  .project-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    transition: all var(--transition-base);
    cursor: pointer;
    opacity: 0;
    transform: translateY(20px);
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-primary);
    box-shadow: 0 20px 40px rgba(50, 69, 255, 0.15);
  }

  .card-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .project-card:hover .card-image {
    transform: scale(1.1);
  }

  .card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .project-card:hover .card-overlay {
    opacity: 1;
  }

  .overlay-buttons {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: var(--font-size-sm);
  }

  .card-content {
    padding: var(--spacing-lg);
  }

  .card-category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(50, 69, 255, 0.1);
    color: var(--color-primary);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: var(--spacing-md);
  }

  .card-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .card-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
  }

  .card-tech-stack {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .tech-badge {
    display: inline-block;
    padding: 0.35rem 0.7rem;
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: 500;
  }

  .view-all-section {
    text-align: center;
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: var(--font-size-lg);
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll animations handled by GSAP */
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animate project cards on scroll
  const cards = document.querySelectorAll('.project-card');
  
  cards.forEach((card, index) => {
    gsap.fromTo(
      card,
      {
        opacity: 0,
        y: 20,
      },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        delay: index * 0.15,
        scrollTrigger: {
          trigger: card,
          start: 'top 80%',
          markers: false,
        },
      }
    );
  });
</script>
