---
import { skillsData } from '../data/skills';
---

<section class="skills section" id="skills">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Tech Stack & Skills</h2>
      <p class="section-subtitle">Technologies and tools I work with</p>
    </div>

    <div class="skills-container">
      {skillsData.map((categoryData, categoryIndex) => (
        <div class="skill-category" data-category={categoryIndex}>
          <h3 class="category-title">{categoryData.category}</h3>
          
          <div class="skills-grid">
            {categoryData.skills.map((skill, skillIndex) => (
              <div class="skill-card" data-skill-index={skillIndex}>
                <div class="skill-icon">{skill.icon}</div>
                <div class="skill-info">
                  <h4 class="skill-name">{skill.name}</h4>
                  <div class="skill-bar">
                    <div class="skill-progress" style={`--proficiency: ${skill.proficiency}%`}></div>
                  </div>
                  <span class="skill-percentage">{skill.proficiency}%</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    background: linear-gradient(135deg, rgba(188, 82, 238, 0.03) 0%, rgba(50, 69, 255, 0.03) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-title {
    font-size: var(--font-size-5xl);
    font-weight: 800;
    margin-bottom: var(--spacing-md);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  .skills-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--spacing-2xl);
  }

  .skill-category {
    opacity: 0;
    transform: translateY(20px);
  }

  .category-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--color-border);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .skill-card {
    display: flex;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    cursor: default;
  }

  .skill-card:hover {
    background: var(--color-bg-secondary);
    border-color: var(--color-primary);
    transform: translateX(8px);
  }

  .skill-icon {
    font-size: var(--font-size-4xl);
    min-width: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .skill-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .skill-name {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .skill-bar {
    width: 100%;
    height: 6px;
    background: var(--color-bg-secondary);
    border-radius: var(--radius-full);
    overflow: hidden;
    margin-top: 4px;
  }

  .skill-progress {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    width: var(--proficiency, 0%);
    transition: width 1s ease-out;
  }

  .skill-percentage {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    font-weight: 500;
    text-align: right;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .skills-container {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: var(--font-size-3xl);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const categories = document.querySelectorAll('.skill-category');

  categories.forEach((category, index) => {
    gsap.fromTo(
      category,
      {
        opacity: 0,
        y: 20,
      },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        delay: index * 0.15,
        scrollTrigger: {
          trigger: category,
          start: 'top 80%',
          markers: false,
        },
      }
    );
  });
</script>
