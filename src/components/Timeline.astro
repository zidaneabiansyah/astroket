---
import { experienceData } from '../data/about';

const experiences = experienceData;
---

<section class="timeline section" id="timeline">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Experience</h2>
      <p class="section-subtitle">My professional journey and key achievements</p>
    </div>

    <div class="timeline-container">
      <div class="timeline-line"></div>
      
      {experiences.map((exp, index) => (
        <div class="timeline-item" data-index={index}>
          <div class="timeline-marker"></div>
          
          <div class="timeline-card">
            <div class="card-header">
              <div>
                <h3 class="company-name">{exp.company}</h3>
                <p class="position-title">{exp.position}</p>
              </div>
              <span class="duration-badge">{exp.duration}</span>
            </div>

            <p class="card-description">{exp.description}</p>

            <div class="achievements">
              <h4 class="achievements-title">Key Achievements:</h4>
              <ul class="achievements-list">
                {exp.achievements.map((achievement) => (
                  <li class="achievement-item">
                    <span class="achievement-icon">✓</span>
                    {achievement}
                  </li>
                ))}
              </ul>
            </div>

            <div class="tech-stack">
              <h4 class="tech-title">Tech Stack:</h4>
              <div class="tech-list">
                {exp.techStack.map((tech) => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    background: var(--color-bg-secondary);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-title {
    font-size: var(--font-size-5xl);
    font-weight: 800;
    margin-bottom: var(--spacing-md);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  .timeline-container {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3xl);
  }

  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    transform: translateX(-50%);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-2xl);
    position: relative;
    opacity: 0;
    transform: translateY(20px);
  }

  .timeline-item:nth-child(even) {
    direction: rtl;
  }

  .timeline-item:nth-child(even) .timeline-card {
    direction: ltr;
  }

  .timeline-marker {
    position: absolute;
    left: 50%;
    top: 20px;
    width: 16px;
    height: 16px;
    background: var(--color-primary);
    border: 4px solid var(--color-bg);
    border-radius: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 4px var(--color-bg-secondary);
    z-index: 10;
  }

  .timeline-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--spacing-2xl);
    transition: all var(--transition-base);
  }

  .timeline-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 20px 40px rgba(50, 69, 255, 0.1);
    transform: translateY(-8px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .company-name {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin: 0 0 4px 0;
    color: var(--color-text);
  }

  .position-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
  }

  .duration-badge {
    padding: 0.5rem 1rem;
    background: rgba(50, 69, 255, 0.1);
    color: var(--color-primary);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 600;
    white-space: nowrap;
  }

  .card-description {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-lg);
  }

  .achievements {
    margin-bottom: var(--spacing-lg);
  }

  .achievements-title {
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--spacing-md) 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .achievements-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .achievement-item {
    display: flex;
    gap: var(--spacing-sm);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }

  .achievement-icon {
    color: var(--color-primary);
    font-weight: 700;
    flex-shrink: 0;
  }

  .tech-stack {
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-lg);
  }

  .tech-title {
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--spacing-md) 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .tech-list {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .tech-tag {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: linear-gradient(135deg, rgba(50, 69, 255, 0.1) 0%, rgba(188, 82, 238, 0.1) 100%);
    color: var(--color-primary);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .timeline-line {
      left: 0;
    }

    .timeline-item,
    .timeline-item:nth-child(even) {
      grid-template-columns: 1fr;
      direction: ltr;
      margin-left: var(--spacing-lg);
    }

    .timeline-item:nth-child(even) .timeline-card {
      direction: ltr;
    }

    .timeline-marker {
      left: 0;
    }

    .section-title {
      font-size: var(--font-size-3xl);
    }

    .company-name {
      font-size: var(--font-size-xl);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const items = document.querySelectorAll('.timeline-item');

  items.forEach((item, index) => {
    gsap.fromTo(
      item,
      {
        opacity: 0,
        y: 20,
      },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        delay: index * 0.15,
        scrollTrigger: {
          trigger: item,
          start: 'top 80%',
          markers: false,
        },
      }
    );
  });
</script>
