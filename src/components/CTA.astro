---
---

<section class="cta section" id="cta">
  <div class="cta-background"></div>
  
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">Ready to work together?</h2>
      <p class="cta-subtitle">
        Let's create something amazing. Whether you have a new project or want to improve an existing one, 
        I'm here to help bring your ideas to life.
      </p>

      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary btn-lg">
          Start Your Project
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4.16669 10H15.8334M15.8334 10L10 4.16669M15.8334 10L10 15.8334" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#" class="btn btn-secondary btn-lg">
          Schedule a Call
        </a>
      </div>

      <div class="cta-stats">
        <div class="stat">
          <div class="stat-value">50+</div>
          <div class="stat-label">Projects Delivered</div>
        </div>
        <div class="stat">
          <div class="stat-value">30+</div>
          <div class="stat-label">Happy Clients</div>
        </div>
        <div class="stat">
          <div class="stat-value">3+</div>
          <div class="stat-label">Years Experience</div>
        </div>
        <div class="stat">
          <div class="stat-value">24/7</div>
          <div class="stat-label">Support Available</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    background: var(--gradient-primary);
    overflow: hidden;
    padding: var(--spacing-3xl) 0;
  }

  .cta-background {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 20% 50%, rgba(188, 82, 238, 0.3) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(240, 65, 255, 0.2) 0%, transparent 50%);
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  .cta-content {
    text-align: center;
    color: white;
  }

  .cta-title {
    font-size: var(--font-size-5xl);
    font-weight: 800;
    margin-bottom: var(--spacing-lg);
    color: white;
  }

  .cta-subtitle {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.9);
    max-width: 700px;
    margin: 0 auto var(--spacing-2xl) auto;
    line-height: 1.8;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-lg);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--spacing-3xl);
  }

  .cta .btn {
    transition: all var(--transition-base);
  }

  .cta .btn-primary {
    background: white;
    color: var(--color-primary);
    font-weight: 700;
  }

  .cta .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
  }

  .cta .btn-secondary {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 2px solid white;
  }

  .cta .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-3px);
  }

  .cta-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--spacing-lg);
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-2xl);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-value {
    font-size: var(--font-size-4xl);
    font-weight: 800;
    color: white;
    margin-bottom: var(--spacing-sm);
  }

  .stat-label {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cta {
      padding: var(--spacing-2xl) 0;
    }

    .cta-title {
      font-size: var(--font-size-3xl);
    }

    .cta-subtitle {
      font-size: var(--font-size-base);
    }

    .cta-buttons {
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .btn-lg {
      width: 100%;
    }

    .cta-stats {
      gap: var(--spacing-md);
      margin-top: var(--spacing-lg);
      padding-top: var(--spacing-lg);
    }

    .stat-value {
      font-size: var(--font-size-2xl);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const ctaSection = document.querySelector('.cta');

  if (ctaSection) {
    gsap.context(() => {
      // Animate CTA on scroll
      gsap.fromTo(
        ctaSection,
        {
          opacity: 0,
          y: 30,
        },
        {
          opacity: 1,
          y: 0,
          duration: 1,
          scrollTrigger: {
            trigger: ctaSection,
            start: 'top 70%',
            markers: false,
          },
        }
      );

      // Animate stats counters
      const stats = document.querySelectorAll('.stat-value');
      stats.forEach((stat) => {
        const finalValue = stat.textContent.replace(/\D/g, '');
        
        gsap.fromTo(
          stat,
          { textContent: '0' },
          {
            textContent: finalValue,
            duration: 2,
            snap: { textContent: 1 },
            scrollTrigger: {
              trigger: stat,
              start: 'top 75%',
              markers: false,
            },
            onUpdate: function() {
              stat.textContent = Math.floor(parseFloat(stat.textContent));
            }
          }
        );
      });
    });
  }
</script>
